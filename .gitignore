# Go build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary and coverage
*.test
*.out
coverage.txt

# Go workspace
# go.work is committed for CI — it uses relative paths only
go.work.sum

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Dependency directories (if vendored)
vendor/

# Debug binaries
__debug_bin*

# Environment files
.env
.env.local

# Node.js
node_modules/
dist/

# Binaries (top-level build output)
bin/

# Platform package binaries (native Go binaries placed by CI)
packages/*/bin/

# But keep the JS launcher scripts in main packages
!packages/ttsgo/bin/
!packages/ttsgo/bin/ttsgo.js
!packages/nestgo/bin/
!packages/nestgo/bin/nestgo.js

# Dummy Test Projects (Keep them, but they inherit node_modules/dist ignore)
# tests/dummy-*/
